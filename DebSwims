<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 20);
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 120);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.feature-card, .pool-form-wrap').forEach(el => observer.observe(el));

  let uploadedPhotos = [];
  const photoInput = document.getElementById('photo-input');
  const uploadArea = document.getElementById('upload-area');
  const previews  = document.getElementById('photo-previews');

  photoInput.addEventListener('change', handleFiles);
  uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('dragover'); });
  uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
  uploadArea.addEventListener('drop', e => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    handleFileList(e.dataTransfer.files);
  });

  function handleFiles(e) { handleFileList(e.target.files); }

  function handleFileList(files) {
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = ev => { uploadedPhotos.push(ev.target.result); renderPreviews(); };
      reader.readAsDataURL(file);
    });
  }

  function renderPreviews() {
    previews.innerHTML = '';
    uploadedPhotos.forEach((src, i) => {
      const wrap = document.createElement('div');
      wrap.className = 'photo-preview-item';
      wrap.innerHTML = `<img src="${src}" alt="Pool photo ${i+1}"><button class="remove-photo" onclick="removePhoto(${i})">✕</button>`;
      previews.appendChild(wrap);
    });
  }

  function removePhoto(i) { uploadedPhotos.splice(i, 1); renderPreviews(); }

  let entries = [
    {
      name: 'Golden Bear Pool',
      location: 'University of California, Berkeley',
      website: 'https://recwell.berkeley.edu/facilities/golden-bear-recreation-pool/',
      type: 'Outdoor Pool',
      desc: 'Six lanes, 25 yards, water temp 79–80 degrees. Locker rooms with showers, lockers (bring your own lock), but swimmers just leave their things on the benches outside. To access the pool, must be a UC Berkeley student, an active Recreation & Wellbeing member, or purchase a $15 day pass, available for purchase online. Children 12 and under not permitted at the pool. Unfortunately, the pool is not wheelchair accessible.',
      tips: 'Check Cal\'s <a href="https://recwell.berkeley.edu/schedules-reservations/lap-swim/" target="_blank" rel="noopener" style="color:var(--wave-blue);">Lap Swim</a> page for hours. There are several friendly regulars at this pool. On hot days, some of the lanes and the benches are taken over by sunbathing students.',
      photos: [],
      date: 'May 25, 2026'
    }
  ];

  renderEntries();

  function submitEntry() {
    const name     = document.getElementById('pool-name').value.trim();
    const location = document.getElementById('pool-location').value.trim();
    const website  = document.getElementById('pool-website').value.trim();
    const type     = document.getElementById('pool-type').value;
    const desc     = document.getElementById('pool-desc').value.trim();
    const tips     = document.getElementById('pool-tips').value.trim();

    if (!name && !desc) { document.getElementById('pool-name').focus(); return; }

    entries.unshift({
      name: name || 'Unnamed H2O', location, website, type, desc, tips,
      photos: [...uploadedPhotos],
      date: new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })
    });

    renderEntries();

    ['pool-name','pool-location','pool-website','pool-desc','pool-tips'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('pool-type').value = '';
    uploadedPhotos = []; renderPreviews();

    const msg = document.getElementById('success-msg');
    msg.style.display = 'block';
    setTimeout(() => msg.style.display = 'none', 3500);
    document.getElementById('entries-section').scrollIntoView({ behavior:'smooth', block:'start' });
  }

  function renderEntries() {
    const grid = document.getElementById('entries-grid');
    if (!entries.length) {
      grid.innerHTML = '<p class="no-entries">No H2O reviews yet — add your first one above!</p>';
      return;
    }
    grid.innerHTML = entries.map(e => `
      <div class="entry-card">
        ${e.photos.length ? `<div class="entry-photos">${e.photos.slice(0,4).map(src=>`<img src="${src}" alt="Pool photo">`).join('')}</div>` : ''}
        <div class="entry-body">
          <div class="entry-meta">
            <span class="entry-pool-name">${e.name}${e.location ? ` <span style="font-family:'Outfit',sans-serif;font-size:0.92rem;font-weight:400;color:var(--text-mid)">· ${e.location}</span>` : ''}${e.type ? ` <span style="font-size:0.75rem;font-weight:500;background:rgba(27,58,107,0.10);color:var(--prussian);padding:2px 10px;border-radius:50px;margin-left:6px;">${e.type}</span>` : ''}</span>
            <span class="entry-date">${e.date}</span>
          </div>
          ${e.desc  ? `<p class="entry-desc">${e.desc}</p>` : ''}
          ${e.tips  ? `<div class="entry-tips"><strong>💡 Tips & Advice</strong>${e.tips}</div>` : ''}
          ${e.website ? `<a href="${e.website}" target="_blank" rel="noopener" class="entry-website">🔗 Visit H2O Website →</a>` : ''}
        </div>
      </div>
    `).join('');
  }
</script>
</body>
